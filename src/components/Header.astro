<header class="w-full m-0 p-0 shadow-xl bg-purple-600">
  <div
    class="max-w-7xl mx-auto flex items-center justify-between px-4 py-5 text-xl"
  >
    <nav class="flex-1 flex justify-center gap-3">
      <a
        class="px-2 py-2 border-b-4 border-transparent transition-colors duration-300 ease-in-out"
        href="/">Home</a
      >
      <a
        class="px-2 py-2 border-b-4 border-transparent transition-colors duration-300 ease-in-out"
        href="/projects">Projects</a
      >
      <a
        class="px-2 py-2 border-b-4 border-transparent transition-colors duration-300 ease-in-out"
        href="/education">Education</a
      >
      <a
        class="px-2 py-2 border-b-4 border-transparent transition-colors duration-300 ease-in-out"
        href="/contact">Contact</a
      >
    </nav>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const html = document.documentElement;

    // Detectar preferencia del sistema
    const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");

    const applyTheme = (isDark) => {
      if (isDark) {
        html.classList.add("dark");
      } else {
        html.classList.remove("dark");
      }
    };

    // Aplicar al cargar
    applyTheme(mediaQuery.matches);

    // Escuchar cambios del sistema en tiempo real
    mediaQuery.addEventListener("change", (e) => {
      applyTheme(e.matches);
    });

    // Marcar link activo
    const links = document.querySelectorAll("nav a");
    const currentPath = window.location.pathname;

    links.forEach((link) => {
      const href = link.getAttribute("href");
      if (href === currentPath) {
        link.classList.add("nav-active");
        link.setAttribute("aria-current", "page");
      } else {
        link.classList.remove("nav-active");
        link.removeAttribute("aria-current");
      }
    });
  });
</script>
